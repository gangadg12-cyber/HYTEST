# Optional public data API key for Korean emergency medical institution lookup.
# Apply from data.go.kr for the National Emergency Medical Center emergency institution API.
EGEN_SERVICE_KEY=
# PUBLIC_DATA_SERVICE_KEY can be used as an alias if the same key is shared by other services.
PUBLIC_DATA_SERVICE_KEY=

# PlayMCP in KC usually provides PORT. Use MCP_PORT for local development if needed.
MCP_PORT=3000
