# PlayMCP in KC usually provides PORT. Use MCP_PORT for local development if needed.
MCP_PORT=3000

# Optional overrides for residential bill estimates.
# Keep empty to use the built-in default assumptions.
CLIMATE_ENVIRONMENT_WON_PER_KWH=
FUEL_ADJUSTMENT_WON_PER_KWH=

# Public Data Portal EV charger API service key.
# Use the encoded key issued by data.go.kr for 한국환경공단_전기자동차 충전소 정보.
EV_CHARGER_SERVICE_KEY=
DATA_GO_KR_SERVICE_KEY=

# Public/location/market API keys for API-first expansion.
# Missing keys make the related tool return dataMode=unavailable instead of demo data.
KEPCO_BIGDATA_API_KEY=
KAKAO_REST_API_KEY=
KAKAO_MOBILITY_REST_API_KEY=
KMA_SHORT_FORECAST_SERVICE_KEY=
KPX_SMP_DEMAND_SERVICE_KEY=
KPX_REC_SPOT_SERVICE_KEY=
KPX_REGIONAL_SOLAR_HOURLY_SERVICE_KEY=

# Optional exact KPX operation endpoints if the public-data detail page exposes a versioned URL.
KPX_SMP_DEMAND_ENDPOINT=
KPX_REC_SPOT_ENDPOINT=
